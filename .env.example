# ============================================================
#  Secrets — copy to .env and fill in. NEVER commit the real .env.
# ============================================================

# Used when generation.provider or embedding.provider = openai.
# This is also the key for any OpenAI-COMPATIBLE proxy (e.g. a local
# FreeLLMAPI gateway on http://localhost:3001/v1 — set generation.base_url
# in config.yaml and put the proxy's key here).
OPENAI_API_KEY=sk-...

# Required only if generation.provider = anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Local providers (KoboldCPP / Ollama / vLLM) need no key —
# the dummy in config.yaml is enough.

# ------------------------------------------------------------------
#  Provider registry (config.yaml `providers:`)
#  Each entry names the env var holding its key via `api_key_env`.
#  Only fill in the ones you actually use — a provider you never select
#  is never constructed, so its key can stay absent.
# ------------------------------------------------------------------
# MiniMax ships TWO key types and they are NOT interchangeable — this is the
# single most common MiniMax setup mistake:
#
#   sk-api-...   pay-as-you-go. Billed from an ACCOUNT BALANCE. Works against
#                https://api.minimax.io/v1  -> providers.minimax
#                With no balance it returns 402 insufficient_balance_error.
#   sk-cp-...    Coding Plan SUBSCRIPTION. Grab it from the Coding Plan page on
#                platform.minimax.io. Works against
#                https://api.minimax.io/anthropic -> providers.minimax_coding
#
# A subscription does NOT fund the pay-as-you-go endpoint. Check your key's
# prefix before debugging the endpoint.
MINIMAX_API_KEY=
MINIMAX_CODING_API_KEY=

# providers.kimi — Moonshot open platform.
MOONSHOT_API_KEY=

# providers.grok — xAI. NOTE: this is an api.x.ai platform key, which is
# billed separately. An X Premium subscription does NOT grant API access.
XAI_API_KEY=

# providers.freellmapi — the local proxy. Marked api_key_optional in
# config.yaml, so leaving this empty is fine.
FREELLMAPI_API_KEY=
